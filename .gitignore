# ── Dependencies ──────────────────────────────────────────────────────────────
/node_modules

# ── Next.js build artifacts ───────────────────────────────────────────────────
/.next/
/out/
/build

# ── Environment / secrets — NEVER commit real API keys ────────────────────────
.env
.env.local
.env.*.local
*.env

# ── Debug / scratch files (committed during dev, should NOT go public) ─────────
*.txt
*.mjs.bak
_pdftest.mjs
curl_err.txt
r_json.txt
r_pdf.txt
rb1.txt
rb2.txt
rh.txt

# ── Large binary / test PDFs ──────────────────────────────────────────────────
*.pdf

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Claude Code local settings (contains internal bash allow-lists) ────────────
.claude/settings.local.json

# ── OS generated ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── TypeScript / build cache ───────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts
