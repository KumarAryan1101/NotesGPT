# 1. Get a FREE key at https://console.groq.com/keys  (no credit card)
# 2. Copy this file to ".env.local"  and paste your key below
# 3. Restart the dev server after changing this file

GROQ_API_KEY=gsk_paste_your_key_here

# Optional: change the model. Defaults to llama-3.3-70b-versatile.
# GROQ_MODEL=llama-3.3-70b-versatile
